## Backend environment variables
## Copy to .env and fill in your keys.

# Required (used for embeddings + primary LLM)
OPENAI_API_KEY=

# Optional (fallback LLM if OpenAI fails/quota)
ANTHROPIC_API_KEY=

# Required for reranking (Cohere API)
COHERE_API_KEY=

# Optional
# CHROMA_PATH=./chroma_data
# CRAWLER_INTERVAL_MINUTES=60
# LOG_LEVEL=INFO
# DEBUG=true
# PORT=8000
# HOST=0.0.0.0